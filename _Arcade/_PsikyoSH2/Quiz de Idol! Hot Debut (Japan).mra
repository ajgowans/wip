<misterromdescription>
	<rbf>PsikyoSH2</rbf>
	<setname>hotdebut</setname>
	<description>Quiz de Idol! Hot Debut (Japan)</description>
	<rotation>horizontal</rotation>
	<year>2000</year>
	<manufacturer>Psikyo</manufacturer>
	<buttons names="Button 1,Button 2,Button 3,Button 4,Start,Coin,Test,Service" />

	<switches default="40">
		<dip bits="6" name="Debug" ids="On,Off"/>
	</switches>

	<rom index="0" md5="" zip="hotdebut.zip" address="0x30000000">
		<interleave output="64">
			<part crc="15da9983" name="0l.u2" map="125600" />
			<part crc="76d7b73f" name="0h.u11" map="1256" />
		</interleave>
		<interleave output="64">
			<part crc="76ea3498" name="1l.u3" map="125600" />
			<part crc="a056859f" name="1h.u12" map="1256" />
		</interleave>
		<interleave output="64">
			<part crc="9d2d1bb1" name="2l.u4" map="125600" />
			<part crc="a7753c4d" name="2h.u13" map="1256" />
		</interleave>
		<part repeat="0x2800000">00</part>
		<interleave output="64">
			<part crc="eef28aa7" name="snd0.u10" map="12345678" />	
		</interleave>
		<part repeat="0x400000">00</part>

		<interleave output="64">
			<part crc="c3b5180b" name="2.u22" map="216500" />
			<part crc="0b0d0027" name="1.u23" map="2165" />
		</interleave>
		<part repeat="0x300000">00</part>
		<part repeat="0x100">00</part>
	</rom>
	<rom index="2" md5="">
		<part>32</part>
	</rom>
	<nvram index="3" size="256" />
</misterromdescription>